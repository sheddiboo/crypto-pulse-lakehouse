# ==========================================
# AWS Configuration
# ==========================================
# NOTE: If you have the AWS CLI configured locally (~/.aws/credentials), 
# you can leave the Access Keys blank. Terraform and Boto3 will find them automatically.
# If not, paste your temporary/sandbox IAM keys here:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
# ==========================================
# Data Lake Infrastructure (Populate after running Terraform)
# ==========================================
RAW_S3_BUCKET=
GOLD_S3_BUCKET=
ECR_REPO_URL=

# ==========================================
# External APIs
# ==========================================
COINGECKO_API_KEY=